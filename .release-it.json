{
  "git": {
    "commitMessage": "Craft v${version} release",
    "tagAnnotation": "Release v${version}",
    "tagName": "v${version}",
    "commitArgs": ["-S"]
  },
  "github": {
    "release": true,
    "draft": true,
    "assets": ["dist/**/*.zip", "dist/**/*.js"],
    "releaseName": "v${version}"
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "after:bump": [
      "npm run build"
    ]
  },
  "plugins": {
    "@release-it/keep-a-changelog": {
      "filename": "CHANGELOG.md",
      "addUnreleased": true,
      "addVersionUrl": true
    }
  }
}