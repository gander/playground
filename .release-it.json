{
  "git": {
    "requireCommits": true,
    "changelog": "npx auto-changelog --stdout --commit-limit false -u"
  },
  "github": {
    "release": true,
    "draft": true,
    "assets": ["dist/**/*.zip", "dist/**/*.user.js", "dist/**/*.meta.js"]
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "after:bump": ["npm run build", "npx auto-changelog -p"]
  }
}