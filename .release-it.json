{
  "git": {
    "requireCommits": true
  },
  "github": {
    "release": true,
    "draft": true,
    "assets": ["dist/**/*.zip", "dist/**/*.user.js", "dist/**/*.meta.js"]
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "after:bump": [
      "npm run build",
      "npx auto-changelog -p -u -l false -t keepachangelog --hide-empty-releases --hide-credit"
    ]
  }
}