{
  "git": {
    "commitMessage": "Craft v${version} release",
    "requireCommits": true,
    "requireCleanWorkingDir": true,
    "tagAnnotation": "Release v${version}",
    "tagName": "v${version}",
    "commitArgs": ["-S"]
  },
  "github": {
    "release": true,
    "draft": true,
    "assets": ["dist/**/*.zip", "dist/**/*.user.js", "dist/**/*.meta.js"],
    "releaseNotes": "npx auto-changelog --stdout --commit-limit false --template compact --hide-empty-releases --hide-credit",
    "releaseName": "v${version}"
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "after:bump": [
      "npm run build",
      "npx auto-changelog --package --commit-limit false --template keepachangelog --hide-empty-releases --hide-credit"
    ]
  }
}