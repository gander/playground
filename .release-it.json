{
  "git": {
    "commitMessage": "Craft v${version} release",
    "tagAnnotation": "Release v${version}",
    "tagName": "v${version}",
    "commitArgs": ["-S"]
  },
  "github": {
    "release": true,
    "draft": true,
    "assets": ["dist/**/*.zip", "dist/**/*.js"],
    "releaseName": "v${version}"
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "after:bump": [
      "npm run build",
      "auto-changelog --package --commit-limit false --hide-credit"
    ]
  }
}